generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  WAITING_FOR_RESPONSE
  COMPLETED
  REJECTED
}

model Request {
  id          String        @id @default(uuid())
  title       String
  clientName  String
  email       String?
  phone       String?
  description String?
  status      RequestStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@map("requests")
}
